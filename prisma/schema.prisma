generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  FACIL
  MEDIO
  DIFICIL
}

model Attraction {
  id               String     @id @default(cuid())
  slug             String     @unique
  name             String
  category         String
  difficulty       Difficulty
  duration         String
  distanceFromCity String
  description      String
  imageUrl         String?
  latitude         Float?
  longitude        Float?
  featured         Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Restaurant {
  id         String   @id @default(cuid())
  name       String
  cuisine    String
  priceRange String
  address    String
  whatsapp   String
  openHours  String
  imageUrl   String?
  partnerTag String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Stay {
  id           String   @id @default(cuid())
  name         String
  rooms        Int
  rating       Float
  contact      String
  averageNight String
  imageUrl     String?
  tags         String[]
  partnerTag   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Guide {
  id             String   @id @default(cuid())
  name           String
  specialty      String
  languages      String[]
  whatsapp       String
  averagePrice   String
  rating         Float
  imageUrl       String?
  iconhaRequired Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Event {
  id              String   @id @default(cuid())
  name            String
  month           String
  approximateDate String
  location        String
  description     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Itinerary {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  duration    String
  profile     String
  budget      String
  description String
  highlights  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PartnerLead {
  id           String   @id @default(cuid())
  name         String
  businessName String
  segment      String
  plan         String
  email        String
  whatsapp     String
  message      String
  createdAt    DateTime @default(now())
}
